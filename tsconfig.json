{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    // tsup's DTS bundler (rollup-plugin-dts) injects a `baseUrl`, which TS 6.0
    // deprecates ahead of removal in 7.0. Silence it until the toolchain stops
    // emitting it; our own tsconfig no longer sets baseUrl/paths.
    "ignoreDeprecations": "6.0",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "templates"]
}
