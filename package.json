{
  "name": "extforge",
  "version": "0.6.0",
  "description": "Lightning-fast browser extension build system with first-class HMR, interactive scaffolding, and cross-browser support (Chrome, Firefox, Safari, Edge — Manifest V3).",
  "type": "module",
  "bin": {
    "extforge": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./logger": {
      "import": "./dist/core/logger/index.js",
      "types": "./dist/core/logger/index.d.ts"
    },
    "./plugins": {
      "import": "./dist/core/plugins/index.js",
      "types": "./dist/core/plugins/index.d.ts"
    },
    "./testing": {
      "import": "./dist/core/testing/index.js",
      "types": "./dist/core/testing/index.d.ts"
    },
    "./testing/vitest": {
      "import": "./dist/core/testing/vitest.js",
      "types": "./dist/core/testing/vitest.d.ts"
    },
    "./storage": {
      "import": "./dist/core/storage/index.js",
      "types": "./dist/core/storage/index.d.ts"
    },
    "./storage/react": {
      "import": "./dist/core/storage/react.js",
      "types": "./dist/core/storage/react.d.ts"
    },
    "./messaging": {
      "import": "./dist/core/messaging/index.js",
      "types": "./dist/core/messaging/index.d.ts"
    },
    "./csui": {
      "import": "./dist/core/csui/index.js",
      "types": "./dist/core/csui/index.d.ts"
    },
    "./env": {
      "import": "./dist/core/env/index.js",
      "types": "./dist/core/env/index.d.ts"
    }
  },
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm -C tests-e2e build:fixtures && pnpm -C tests-e2e test",
    "test:e2e:install": "pnpm -C tests-e2e install-browsers",
    "examples:build": "pnpm -r --filter \"@extforge-example/*\" build",
    "lint": "eslint src scripts",
    "format": "prettier --write 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "compat:rebuild": "tsx src/core/compat/build-data.ts",
    "compat:check-freshness": "tsx scripts/check-bcd-freshness.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run build && npm run test",
    "docs:gen": "tsx scripts/gen-docs.ts",
    "docs:gen:brand": "tsx scripts/gen-brand-css.ts",
    "docs:gen:config": "tsx scripts/gen-config-reference.ts",
    "docs:gen:errors": "tsx scripts/gen-error-codes.ts",
    "docs:gen:plugins": "tsx scripts/gen-plugin-reference.ts",
    "docs:dev": "pnpm docs:gen && pnpm --filter extforge-docs dev",
    "docs:build": "pnpm docs:gen && pnpm --filter extforge-docs build"
  },
  "dependencies": {
    "@arshad-shah/clif": "^1.3.0",
    "@arshad-shah/config-kit": "^2.0.0",
    "@arshad-shah/log-kit": "^1.1.0",
    "esbuild": "^0.28.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@mdn/browser-compat-data": "^8.0.3",
    "@swc/core": "^1.15.41",
    "@types/chrome": "^0.1.43",
    "@types/node": "^22.19.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.5.0",
    "happy-dom": "^20.10.3",
    "prettier": "^3.8.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "ts-morph": "^28.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "@swc/core": ">=1.7.0",
    "esbuild": ">=0.24.0",
    "react": ">=18.0.0",
    "react-refresh": ">=0.14.0"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": false
    },
    "@swc/core": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-refresh": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.0.0",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "browser-extension",
    "chrome-extension",
    "firefox-addon",
    "safari-extension",
    "edge-extension",
    "manifest-v3",
    "mv3",
    "hmr",
    "hot-reload",
    "build-tool",
    "bundler",
    "scaffold",
    "cli",
    "cross-browser",
    "esbuild",
    "webextension"
  ],
  "author": {
    "name": "Arshad Shah",
    "url": "https://github.com/arshad-shah"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arshad-shah/extforge.git"
  },
  "bugs": {
    "url": "https://github.com/arshad-shah/extforge/issues"
  },
  "homepage": "https://extforge.arshadshah.com",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "pnpm": {
    "overrides": {
      "esbuild@<0.28.1": ">=0.28.1",
      "devalue@>=5.6.3 <5.8.1": ">=5.8.1"
    }
  }
}
