{
  "name": "extforge",
  "version": "0.2.0",
  "description": "Lightning-fast browser extension build system with first-class HMR, interactive scaffolding, and cross-browser support (Chrome, Firefox, Safari, Edge — Manifest V3).",
  "type": "module",
  "bin": {
    "extforge": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./logger": {
      "import": "./dist/core/logger/index.js",
      "types": "./dist/core/logger/index.d.ts"
    },
    "./plugins": {
      "import": "./dist/core/plugins/index.js",
      "types": "./dist/core/plugins/index.d.ts"
    },
    "./testing": {
      "import": "./dist/core/testing/index.js",
      "types": "./dist/core/testing/index.d.ts"
    },
    "./testing/vitest": {
      "import": "./dist/core/testing/vitest.js",
      "types": "./dist/core/testing/vitest.d.ts"
    }
  },
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "compat:rebuild": "tsx src/core/compat/build-data.ts",
    "prepublishOnly": "npm run typecheck && npm run build && npm run test"
  },
  "dependencies": {
    "c12": "^2.0.1",
    "chokidar": "^4.0.3",
    "citty": "^0.1.6",
    "consola": "^3.2.3",
    "defu": "^6.1.4",
    "esbuild": "^0.24.0",
    "fast-glob": "^3.3.2",
    "glob": "^11.0.0",
    "pathe": "^1.1.2",
    "picocolors": "^1.1.1",
    "pkg-types": "^1.2.1",
    "prompts": "^2.4.2",
    "ws": "^8.18.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@mdn/browser-compat-data": "^7.3.14",
    "@types/node": "^22.0.0",
    "@types/prompts": "^2.4.9",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "esbuild": ">=0.24.0"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": false
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "browser-extension",
    "chrome-extension",
    "firefox-addon",
    "safari-extension",
    "edge-extension",
    "manifest-v3",
    "mv3",
    "hmr",
    "hot-reload",
    "build-tool",
    "bundler",
    "scaffold",
    "cli",
    "cross-browser",
    "esbuild",
    "webextension"
  ],
  "author": {
    "name": "Arshad Shah",
    "url": "https://github.com/arshad-shah"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arshad-shah/extforge.git"
  },
  "bugs": {
    "url": "https://github.com/arshad-shah/extforge/issues"
  },
  "homepage": "https://github.com/arshad-shah/extforge#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
