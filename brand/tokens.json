{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "ExtForge",
  "version": "1.0.0",
  "color": {
    "brand": {
      "violet":     { "value": "#5B21B6", "comment": "Primary mark color (light bg)" },
      "violet-soft":{ "value": "#A78BFA", "comment": "Primary mark color (dark bg)" },
      "amber":      { "value": "#FBBF24", "comment": "Accent — the chevron, highlights, focused state" },
      "amber-deep": { "value": "#D97706", "comment": "Pressed/active accent" }
    },
    "ink": {
      "primary":    { "value": "#0F172A", "comment": "Body text on light bg" },
      "secondary":  { "value": "#475569" },
      "muted":      { "value": "#94A3B8" }
    },
    "surface": {
      "page":       { "value": "#FFFFFF" },
      "subtle":     { "value": "#F8FAFC" },
      "raised":     { "value": "#F1F5F9" },
      "border":     { "value": "#E2E8F0" }
    },
    "ink-dark": {
      "primary":    { "value": "#F8FAFC" },
      "secondary":  { "value": "#CBD5E1" },
      "muted":      { "value": "#64748B" }
    },
    "surface-dark": {
      "page":       { "value": "#0B0F1A" },
      "subtle":     { "value": "#0F172A" },
      "raised":     { "value": "#1E293B" },
      "border":     { "value": "#334155" }
    },
    "semantic": {
      "success":    { "value": "#10B981" },
      "warning":    { "value": "#F59E0B" },
      "error":      { "value": "#EF4444" },
      "info":       { "value": "#3B82F6" }
    }
  },
  "font": {
    "family": {
      "sans": { "value": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif" },
      "mono": { "value": "'JetBrains Mono', ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, monospace" }
    },
    "size": {
      "xs":   { "value": "12px" },
      "sm":   { "value": "14px" },
      "base": { "value": "16px" },
      "lg":   { "value": "18px" },
      "xl":   { "value": "24px" },
      "2xl":  { "value": "32px" },
      "3xl":  { "value": "48px" }
    },
    "weight": {
      "regular": { "value": 400 },
      "medium":  { "value": 500 },
      "bold":    { "value": 700 }
    },
    "tracking": {
      "tight":  { "value": "-0.02em", "comment": "Wordmark, headlines" },
      "normal": { "value": "0" }
    }
  },
  "radius": {
    "sm": { "value": "4px" },
    "md": { "value": "8px" },
    "lg": { "value": "12px" }
  },
  "wordmark": {
    "casing":   { "value": "lowercase" },
    "spelling": { "value": "extforge", "comment": "always one word, lowercase. The package name is `extforge`. The product name in prose is `ExtForge` (capitalized, like Vite/Bun)." }
  }
}
