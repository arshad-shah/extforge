# Committed on purpose: these are PUBLIC, non-secret demo values.
#
# Only keys prefixed EXTFORGE_PUBLIC_ are inlined into the bundle and shipped
# to the browser. Everything else stays in the build-process environment and
# never reaches client code.

# ↓ Inlined into the bundle (readable as import.meta.env.EXTFORGE_PUBLIC_*)
EXTFORGE_PUBLIC_API_BASE=https://api.example.com
EXTFORGE_PUBLIC_FEATURE_FLAG=true

# ↓ NOT inlined — demonstrates the public/private split. Put real secrets in
#   .env.local (gitignored) instead; this one is a harmless placeholder.
EXTFORGE_BACKEND_TOKEN=placeholder-never-shipped-to-the-browser
